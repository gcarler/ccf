import re

with open('/root/ccf/backend/crud/cms.py', 'r') as f:
    content = f.read()

replacements = {
    'site_id: int': 'site_id: uuid.UUID',
    'theme_id: int': 'theme_id: uuid.UUID',
    'menu_id: int': 'menu_id: uuid.UUID',
    'item_id: int': 'item_id: uuid.UUID',
    'page_id: int': 'page_id: uuid.UUID',
    'section_id: int': 'section_id: uuid.UUID',
    'version_id: int': 'version_id: uuid.UUID',
    'asset_id: int': 'asset_id: uuid.UUID',
    'announcement_id: int': 'announcement_id: uuid.UUID',
    'testimonial_id: int': 'testimonial_id: uuid.UUID',
}

lines = content.split('\n')
result = []
for line in lines:
    stripped = line.lstrip()
    if stripped.startswith('def '):
        for old, new in replacements.items():
            line = line.replace(old, new)
    result.append(line)

with open('/root/ccf/backend/crud/cms.py', 'w') as f:
    f.write('\n'.join(result))

print('Done')
