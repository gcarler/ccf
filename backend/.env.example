# ── CCF Mesh — Backend Environment ─────────────────────────────────────
# Copy this file to .env and adjust values for your deployment.
# The Settings class in backend/core/config.py reads these automatically.

# Runtime environment: local | development | staging | production
ENVIRONMENT=local

# Database connection string
# SQLite (local dev):
DATABASE_URL=sqlite:////root/ccf/ccf_final.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://postgres:changeme@localhost:5432/ccf_db

# Security — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-strong-random-value
# Fernet key for symmetric encryption — generate with: python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=1

# Cookie settings — MUST be true in production
ACCESS_TOKEN_COOKIE_NAME=mesh_access
ACCESS_TOKEN_COOKIE_SECURE=false

# CORS — explicit production domains (no wildcards in production)
# Example: CORS_ORIGINS=["https://ccfministerio.com","https://www.ccfministerio.com","https://app.ccfministerio.com"]
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Redis (caching, rate-limiting, sessions)
REDIS_URL=redis://localhost:6379/0

# Kafka / event bus (optional — RedisEventBus is the default)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# File uploads
UPLOADS_DIR=uploads

# Analytics (DuckDB)
ANALYTICS_DB_PATH=analytics/warehouse.duckdb

# OpenTelemetry (optional)
ENABLE_OTEL=false
OTEL_ENDPOINT=http://localhost:4317

# Feature flags (JSON dict)
FEATURE_FLAGS={}

# Password reset / email verification
PASSWORD_RESET_EXPIRE_MINUTES=60
EMAIL_VERIFICATION_EXPIRE_HOURS=48

# Legacy — use Alembic instead
RUN_STARTUP_SCHEMA_FIXES=false

# SMTP Email
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ccfministerio.com
SMTP_FROM_NAME=CCF Ministerio
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Other
OPENROUTER_API_KEY=
