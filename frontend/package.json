{
    "name": "ccf-frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -H 0.0.0.0",
        "build": "rm -rf .next && node scripts/with-next-lock.mjs next build",
        "start": "next start",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:strict": "eslint src --ext .ts,.tsx --max-warnings 0",
        "lint:critical": "eslint src/app/admin/settings src/app/admin/analytics/candidates src/app/admin/analytics/web-vitals src/app/api/analytics/web-vitals src/app/settings src/app/crm/settings src/app/crm/analytics src/app/groups/analytics --ext .ts,.tsx --max-warnings 0",
        "typegen": "node scripts/with-next-lock.mjs next typegen",
        "typecheck": "npm run typegen && tsc --noEmit",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:auth": "playwright test --grep @auth",
        "test:e2e:auth:managed": "powershell -Command \"$env:PLAYWRIGHT_BASE_URL='http://localhost:4173'; $env:E2E_AUTH_ENABLED='1'; $env:NEXT_PUBLIC_API_URL='http://127.0.0.1:8000/api'; $env:API_BASE_URL='http://127.0.0.1:8000/api'; $p = Start-Process -FilePath npm.cmd -ArgumentList @('run','dev','--','-p','4173') -PassThru -WindowStyle Hidden; try { Start-Sleep -Seconds 15; npx.cmd playwright test --grep '@auth' --workers 1 --reporter line } finally { if ($p -and -not $p.HasExited) { Stop-Process -Id $p.Id -Force -ErrorAction SilentlyContinue } }\"",
        "test:e2e:seed-user": "node tests/e2e/seed-auth-user.mjs",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "perf:lighthouse": "node scripts/run-lighthouse.mjs",
        "quality:gate": "node scripts/quality-gate.mjs"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-slot": "^1.0.2",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.26",
        "@tiptap/extension-placeholder": "^3.21.0",
        "@tiptap/extension-task-item": "^3.21.0",
        "@tiptap/extension-task-list": "^3.21.0",
        "@tiptap/react": "^3.21.0",
        "@tiptap/starter-kit": "^3.21.0",
        "@tiptap/suggestion": "^3.21.0",
        "ag-grid-community": "^35.3.0",
        "ag-grid-react": "^35.3.0",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "fabric": "^7.2.0",
        "framer-motion": "^11.2.6",
        "lucide-react": "^0.378.0",
        "next": "^15.5.15",
        "qrcode.react": "^4.2.0",
        "react": "^18",
        "react-day-picker": "^9.14.0",
        "react-dom": "^18",
        "react-force-graph-2d": "^1.29.1",
        "react-hook-form": "^7.76.1",
        "react-select": "^5.10.2",
        "react-toastify": "^11.0.5",
        "recharts": "^3.8.1",
        "sharp": "^0.35.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^2.6.1",
        "tippy.js": "^6.3.7",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@playwright/test": "^1.55.0",
        "@storybook/addon-a11y": "^10.3.3",
        "@storybook/addon-docs": "^10.3.3",
        "@storybook/addon-onboarding": "^10.3.3",
        "@storybook/addon-webpack5-compiler-swc": "^4.0.3",
        "@storybook/react-webpack5": "^10.3.3",
        "@types/node": "^20",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "@vitest/coverage-v8": "^1.6.1",
        "autoprefixer": "^10.4.27",
        "eslint": "^8",
        "eslint-config-next": "^15.5.15",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-storybook": "^10.3.3",
        "lighthouse": "^13.0.3",
        "postcss": "^8.5.8",
        "prettier": "^3.8.3",
        "storybook": "^10.3.3",
        "tailwindcss": "^3.4.19",
        "typescript": "^5",
        "vitest": "^1.5.0"
    }
}
