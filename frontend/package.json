{
    "name": "ccf-frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -H 0.0.0.0",
        "build": "node scripts/build-safe.mjs",
        "start": "next start",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:strict": "eslint src --ext .ts,.tsx --max-warnings 0",
        "lint:critical": "eslint src/app/plataforma/admin/settings src/app/plataforma/admin/analytics src/app/plataforma/admin/reports src/app/api/analytics/web-vitals src/app/plataforma/settings src/app/plataforma/crm/settings src/app/plataforma/crm/analytics src/app/plataforma/groups/analytics --ext .ts,.tsx --max-warnings 0",
        "typegen": "node scripts/with-next-lock.mjs next typegen",
        "typecheck": "npm run typegen && tsc --noEmit",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:auth": "playwright test --grep @auth",
        "test:e2e:crm": "node scripts/run-managed-playwright.mjs --auth tests/e2e/crm/smoke.spec.ts tests/e2e/crm/personas-live.spec.ts tests/e2e/crm/groups-admin-live.spec.ts tests/e2e/crm/automations-builder-live.spec.ts && node scripts/run-managed-playwright.mjs tests/e2e/crm/dashboard.spec.ts tests/e2e/crm/groups-admin.spec.ts",
        "test:e2e:crm:deep": "node scripts/run-managed-playwright.mjs tests/e2e/crm/dashboard.spec.ts tests/e2e/crm/groups-admin.spec.ts tests/e2e/crm/persona-detail.spec.ts tests/e2e/crm/messaging.spec.ts tests/e2e/crm/resources.spec.ts tests/e2e/crm/pipeline-deep.spec.ts",
        "test:e2e:academy": "playwright test tests/e2e/academy/smoke.spec.ts && node scripts/run-managed-playwright.mjs tests/e2e/academy/profile-detail.spec.ts",
        "test:e2e:academy:deep": "node scripts/run-managed-playwright.mjs tests/e2e/academy/profile-detail.spec.ts",
        "test:e2e:academy:multi-role": "node scripts/run-managed-playwright.mjs --academy-roles tests/e2e/academy/multi-role-flow.spec.ts",
        "test:e2e:projects": "playwright test tests/e2e/projects/smoke.spec.ts && node scripts/run-managed-playwright.mjs --auth tests/e2e/projects/detail.spec.ts",
        "test:e2e:projects:detail": "node scripts/run-managed-playwright.mjs --auth tests/e2e/projects/detail.spec.ts",
        "test:e2e:messaging": "playwright test tests/e2e/messaging/smoke.spec.ts && node scripts/run-managed-playwright.mjs tests/e2e/messaging/direct-messages.spec.ts",
        "test:e2e:messaging:deep": "node scripts/run-managed-playwright.mjs tests/e2e/messaging/direct-messages.spec.ts",
        "test:e2e:agenda": "playwright test tests/e2e/agenda/smoke.spec.ts && node scripts/run-managed-playwright.mjs tests/e2e/agenda/calendar-events.spec.ts",
        "test:e2e:agenda:deep": "node scripts/run-managed-playwright.mjs tests/e2e/agenda/calendar-events.spec.ts",
        "test:e2e:evangelism": "node scripts/run-managed-playwright.mjs tests/e2e/evangelism/smoke.spec.ts tests/e2e/evangelism/sessions-detail.spec.ts tests/e2e/evangelism/rankings-multiplication.spec.ts tests/e2e/evangelism/events-scanner.spec.ts",
        "test:e2e:evangelism:deep": "node scripts/run-managed-playwright.mjs tests/e2e/evangelism/sessions-detail.spec.ts tests/e2e/evangelism/rankings-multiplication.spec.ts tests/e2e/evangelism/events-scanner.spec.ts",
        "test:e2e:cms": "node scripts/run-managed-playwright.mjs --auth tests/e2e/cms/smoke.spec.ts && node scripts/run-managed-playwright.mjs tests/e2e/cms/pages-preview.spec.ts",
        "test:e2e:cms:deep": "node scripts/run-managed-playwright.mjs tests/e2e/cms/pages-preview.spec.ts",
        "test:e2e:cms:public": "node scripts/run-managed-playwright.mjs tests/e2e/cms-public-contract.spec.ts",
        "test:e2e:modules": "playwright test tests/e2e/projects/smoke.spec.ts tests/e2e/crm/smoke.spec.ts tests/e2e/academy/smoke.spec.ts tests/e2e/messaging/smoke.spec.ts tests/e2e/agenda/smoke.spec.ts tests/e2e/evangelism/smoke.spec.ts tests/e2e/cms/smoke.spec.ts tests/e2e/platform-critical-routes.spec.ts",
        "test:e2e:modules:matrix": "node tests/e2e/run-modules-matrix.mjs",
        "test:e2e:platform": "playwright test tests/e2e/platform-critical-routes.spec.ts",
        "test:e2e:seed-projects-demo": "node tests/e2e/seed-projects-demo.mjs",
        "test:e2e:auth:managed": "node scripts/run-managed-playwright.mjs --auth --grep @auth --workers 1 --reporter line",
        "test:e2e:seed-user": "node tests/e2e/seed-auth-user.mjs",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "quality:gate": "node scripts/quality-gate.mjs"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-slot": "^1.0.2",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.26",
        "@tiptap/extension-placeholder": "^3.21.0",
        "@tiptap/extension-task-item": "^3.21.0",
        "@tiptap/extension-task-list": "^3.21.0",
        "@tiptap/react": "^3.21.0",
        "@tiptap/starter-kit": "^3.21.0",
        "@tiptap/suggestion": "^3.21.0",
        "@xyflow/react": "^12.11.2",
        "ag-grid-community": "^35.3.0",
        "ag-grid-react": "^35.3.0",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "fabric": "^7.2.0",
        "framer-motion": "^11.2.6",
        "lucide-react": "^0.378.0",
        "next": "^15.5.15",
        "qrcode.react": "^4.2.0",
        "react": "^18",
        "react-day-picker": "^9.14.0",
        "react-dom": "^18",
        "react-force-graph-2d": "^1.29.1",
        "react-hook-form": "^7.76.1",
        "react-select": "^5.10.2",
        "react-toastify": "^11.0.5",
        "recharts": "^3.8.1",
        "sanitize-html": "^2.17.5",
        "sharp": "^0.35.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^2.6.1",
        "tippy.js": "^6.3.7",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@playwright/test": "^1.55.0",
        "@storybook/addon-a11y": "^10.3.3",
        "@storybook/addon-docs": "^10.3.3",
        "@storybook/addon-onboarding": "^10.3.3",
        "@storybook/addon-webpack5-compiler-swc": "^4.0.3",
        "@storybook/react-webpack5": "^10.3.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "@vitest/coverage-v8": "^1.6.1",
        "autoprefixer": "^10.4.27",
        "eslint": "^8",
        "eslint-config-next": "^15.5.15",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-storybook": "^10.3.3",
        "jest-axe": "^10.0.0",
        "postcss": "^8.5.8",
        "prettier": "^3.8.3",
        "storybook": "^10.3.3",
        "tailwindcss": "^3.4.19",
        "typescript": "^5",
        "vitest": "^1.5.0"
    }
}
