# Core settings
ENVIRONMENT=local
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-strong-secret
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ccf_db
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=replace-with-strong-password
REDIS_URL=redis://:replace-with-strong-password@localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
UPLOADS_DIR=uploads
# Generate: python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# MinIO / object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=ccf
MINIO_SECRET_KEY=ccfsecret
MINIO_BUCKET=ccf-uploads

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
