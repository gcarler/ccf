# Coverage config — Quality Gate baseline
# ----------------------------------------------------------------------------
# Objetivo: la métrica --cov-fail-under=70% en pytest.ini debe medir la lógica
# de negocio. Migraciones Alembic, scripts de seeds puntuales y archivos cuya
# naturaleza no es apta para cobertura unitaria tradicional (data sinks,
# orquestador IA no determinista) se excluyen explícitamente.
#
# Notas operativas:
#   - branch = False para mantener consistencia con la cobertura histórica
#     (coverage.json tiene branch_coverage=false). Activarla duplicaría el
#     número de métricas y podría forzar un false negative en --cov-fail-under.
#   - tests/* NO está en omit porque pytest-cov ya excluye los tests del
#     package que se está midiendo explícitamente vía --cov=backend.
#   - analytics/queries.py y analytics/event_sink.py son sinks de datos
#     (DuckDB); su cobertura se valida con pruebas E2E del pipeline.
# ----------------------------------------------------------------------------
[run]
branch = False
omit =
    alembic/versions/*
    backend/alembic/*
    backend/scripts/*
    backend/archive/*
    backend/analytics/event_sink.py
    backend/analytics/queries.py
    backend/agents/orchestrator.py
    */__pycache__/*
    */migrations/*

[report]
show_missing = True
skip_covered = False
sort = -Cover
precision = 2
fail_under = 70
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    \.\.\.

[html]
directory = coverage_html_report
