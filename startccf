#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUN_DIR="$ROOT_DIR/.run"
BACKEND_PID_FILE="$RUN_DIR/backend.pid"
FRONTEND_PID_FILE="$RUN_DIR/frontend.pid"
BACKEND_LOG="$RUN_DIR/backend-dev.log"
FRONTEND_LOG="$RUN_DIR/frontend-dev.log"

mkdir -p "$RUN_DIR"

is_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1
}

start_backend() {
  if [[ -f "$BACKEND_PID_FILE" ]]; then
    local pid
    pid="$(cat "$BACKEND_PID_FILE")"
    if is_running "$pid"; then
      echo "Backend already running (PID $pid)"
      return
    fi
  fi

  (
    cd "$ROOT_DIR"
    python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 >"$BACKEND_LOG" 2>&1 &
    echo $! >"$BACKEND_PID_FILE"
  )
  echo "Backend started on http://localhost:8000"
}

start_frontend() {
  if [[ -f "$FRONTEND_PID_FILE" ]]; then
    local pid
    pid="$(cat "$FRONTEND_PID_FILE")"
    if is_running "$pid"; then
      echo "Frontend already running (PID $pid)"
      return
    fi
  fi

  (
    cd "$ROOT_DIR/frontend"
    npm run dev -- --hostname 0.0.0.0 --port 3000 >"$FRONTEND_LOG" 2>&1 &
    echo $! >"$FRONTEND_PID_FILE"
  )
  echo "Frontend started on http://localhost:3000"
}

start_backend
start_frontend

echo
echo "CCF running:"
echo "- Frontend: http://localhost:3000"
echo "- Backend:  http://localhost:8000/docs"
echo
echo "Logs:"
echo "- $BACKEND_LOG"
echo "- $FRONTEND_LOG"
echo
echo "Stop with: ./stopccf"
